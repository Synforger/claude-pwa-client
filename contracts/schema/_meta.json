{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-pwa-client.v2/contracts/_meta.json",
  "title": "claude-pwa-client v2 contract schema meta",
  "description": "schema/*.yaml の meta-schema。 root の kind field で 4 種類の sub-schema に oneOf 分岐 (= sse-events / ws-channels / http-endpoints / lifecycle)。 ajv で typo / 必須欠落を 1 コマンドで検知。",
  "type": "object",
  "required": ["kind", "version", "schema_version"],
  "properties": {
    "kind": { "enum": ["sse-events", "ws-channels", "http-endpoints", "lifecycle"] },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
  },
  "oneOf": [
    { "$ref": "#/$defs/sseEvents" },
    { "$ref": "#/$defs/wsChannels" },
    { "$ref": "#/$defs/httpEndpoints" },
    { "$ref": "#/$defs/lifecycle" }
  ],
  "$defs": {
    "fieldSchema": {
      "type": "object",
      "description": "JSON Schema 2020-12 互換の property 記述 (= 必要最小サブセット)",
      "properties": {
        "type": { "enum": ["string", "integer", "number", "boolean", "object", "array", "null"] },
        "description": { "type": "string" },
        "enum": { "type": "array" },
        "const": {},
        "nullable": { "type": "boolean" },
        "items": { "$ref": "#/$defs/fieldSchema" },
        "properties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/fieldSchema" } },
        "required": { "type": "array", "items": { "type": "string" } },
        "additionalProperties": { "oneOf": [ { "type": "boolean" }, { "$ref": "#/$defs/fieldSchema" } ] },
        "oneOf": { "type": "array", "items": { "$ref": "#/$defs/fieldSchema" } },
        "anyOf": { "type": "array", "items": { "$ref": "#/$defs/fieldSchema" } },
        "format": { "type": "string" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "additionalProperties": false
    },
    "sseEvents": {
      "type": "object",
      "properties": {
        "kind": { "const": "sse-events" },
        "events": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["description", "type", "required", "properties", "invariants"],
            "properties": {
              "description": { "type": "string", "minLength": 1 },
              "type": { "const": "object" },
              "required": { "type": "array", "items": { "type": "string" } },
              "properties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/fieldSchema" } },
              "additionalProperties": { "type": "boolean" },
              "invariants": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
              "trigger": { "type": "string" },
              "consumer": { "type": "string", "description": "frontend での消費先 (= 例: useChatStream → processStreamEvent)" },
              "render_target": { "type": "string", "description": "chat / status_bar / overlay / skip 等" }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["events"]
    },
    "wsChannels": {
      "type": "object",
      "properties": {
        "kind": { "const": "ws-channels" },
        "channels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["path", "direction", "frame_format", "lifecycle", "invariants"],
            "properties": {
              "path": { "type": "string", "pattern": "^/" },
              "direction": { "enum": ["client_to_server", "server_to_client", "bidirectional"] },
              "frame_format": { "enum": ["binary", "text", "mixed"] },
              "client_to_server": { "type": "array", "items": { "$ref": "#/$defs/wsFrame" } },
              "server_to_client": { "type": "array", "items": { "$ref": "#/$defs/wsFrame" } },
              "lifecycle": {
                "type": "object",
                "properties": {
                  "connect": { "type": "string" },
                  "reconnect": { "type": "string" },
                  "heartbeat": { "type": "string" },
                  "on_reconnect": { "type": "string" },
                  "bg_fg": { "type": "string" },
                  "disconnect": { "type": "string" }
                },
                "additionalProperties": false
              },
              "auth": { "type": "string" },
              "invariants": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["channels"]
    },
    "wsFrame": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["binary", "text"] },
        "description": { "type": "string" },
        "schema": { "$ref": "#/$defs/fieldSchema" }
      },
      "additionalProperties": false
    },
    "httpEndpoints": {
      "type": "object",
      "properties": {
        "kind": { "const": "http-endpoints" },
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["method", "path", "description", "auth", "invariants"],
            "properties": {
              "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "path": { "type": "string", "pattern": "^/" },
              "description": { "type": "string" },
              "request_body": { "$ref": "#/$defs/fieldSchema" },
              "request_query": { "type": "object", "additionalProperties": { "$ref": "#/$defs/fieldSchema" } },
              "response": { "$ref": "#/$defs/fieldSchema" },
              "response_kind": { "enum": ["json", "sse", "multipart", "raw"] },
              "auth": { "enum": ["tailnet", "localhost", "uid_check", "none"] },
              "rate_limit": { "type": "string" },
              "invariants": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "implementation": { "type": "string", "description": "backend file:func reference" }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["endpoints"]
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "kind": { "const": "lifecycle" },
        "transports": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["states", "transitions", "invariants"],
            "properties": {
              "description": { "type": "string" },
              "states": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
              "transitions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["from", "to", "trigger"],
                  "properties": {
                    "from": { "type": "string" },
                    "to": { "type": "string" },
                    "trigger": { "type": "string" },
                    "action": { "type": "string" },
                    "timeout_ms": { "type": "integer" }
                  },
                  "additionalProperties": false
                },
                "minItems": 1
              },
              "invariants": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["transports"]
    }
  }
}
