#!/bin/bash
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"

# -----------------------------------------------------------------------------
# 1. Anonymity scan: refuse commits introducing personal identifiers or
#    prior-employer / host names. Same PCRE as .github/workflows/anon-check.yml
#    (mirrored in .tooling/local-ci/anon-scan.sh). Staged files only — fast.
# -----------------------------------------------------------------------------
SCANNER="${REPO_ROOT}/.tooling/local-ci/anon-scan.sh"
if [ -x "${SCANNER}" ]; then
    staged="$(git diff --cached --name-only --diff-filter=ACMRT)"
    if [ -n "${staged}" ]; then
        abs_staged=""
        while IFS= read -r f; do
            [ -z "${f}" ] && continue
            abs_staged="${abs_staged}${REPO_ROOT}/${f}"$'\n'
        done <<< "${staged}"
        ANON_SCAN_PATHS="${abs_staged}" bash "${SCANNER}"
    fi
else
    echo "warning: ${SCANNER} not found / not executable; skipping anon scan."
fi

# -----------------------------------------------------------------------------
# 2. Backend flake8 over staged Python files (critical-only set: syntax /
#    undefined names / invalid f-string / break-outside-loop). Catches AI-
#    generated breakage before commit; style nits are deferred to `task lint`.
# -----------------------------------------------------------------------------
staged_py="$(git diff --cached --name-only --diff-filter=ACMRT | grep -E '^backend/.*\.py$' || true)"
if [ -n "${staged_py}" ]; then
    if command -v flake8 >/dev/null 2>&1; then
        # shellcheck disable=SC2086
        flake8 ${staged_py} || {
            echo ""
            echo "flake8 failed on staged backend files. Fix and re-stage, or commit with --no-verify if intentional."
            exit 1
        }
    else
        echo "warning: flake8 not installed; skipping backend lint. Run: pip install -r backend/requirements.txt"
    fi
fi

# -----------------------------------------------------------------------------
# 3. Frontend ESLint over staged JS/JSX/TS/TSX files under frontend/src/.
#    npx defers to frontend/node_modules; if ESLint isn't installed yet
#    (= fresh clone), the check is skipped with a hint.
# -----------------------------------------------------------------------------
staged_js="$(git diff --cached --name-only --diff-filter=ACMRT | grep -E '^frontend/src/.*\.(js|jsx|ts|tsx)$' || true)"
if [ -n "${staged_js}" ]; then
    if [ -d "${REPO_ROOT}/frontend/node_modules/eslint" ]; then
        # Strip frontend/ prefix so paths are relative to the eslint config dir.
        rel_paths="$(echo "${staged_js}" | sed 's|^frontend/||')"
        # shellcheck disable=SC2086
        (cd "${REPO_ROOT}/frontend" && npx --no-install eslint ${rel_paths}) || {
            echo ""
            echo "ESLint failed on staged frontend files. Fix and re-stage, or commit with --no-verify if intentional."
            exit 1
        }
    else
        echo "warning: frontend/node_modules/eslint missing; skipping frontend lint. Run: cd frontend && npm install"
    fi
fi

# -----------------------------------------------------------------------------
# 4. Secret scan over staged files. Pattern-based; catches RSA / SSH private
#    keys and well-known token formats before they reach git history. Reuses
#    the same gitleaks binary used in the 2026-06-29 audit. Skipped (with hint)
#    if gitleaks isn't installed locally — install via `brew install gitleaks`.
# -----------------------------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1; then
    # `gitleaks protect --staged` scans only what's in the index. Exit 1 on hit.
    gitleaks protect --staged --redact --no-banner 2>&1 || {
        echo ""
        echo "gitleaks found secrets in staged files. Remove them or commit with"
        echo "--no-verify only if you have verified the match is a false positive."
        exit 1
    }
else
    echo "warning: gitleaks not installed; skipping secret scan. Run: brew install gitleaks"
fi

# -----------------------------------------------------------------------------
# 5. W2 residue audit: detect J-7/J-8/J-9 shape regressions (state double-
#    management, orphan setters, css absolute without relative ancestor).
#    Runs only when staged files touch the surfaces the audit cares about
#    (state/, features/, layout/, *.css under frontend/src/) — backend or
#    docs-only commits skip. The script self-scans frontend/src/ so its
#    runtime is proportional to the tree, not the staged set; conditioning
#    on staged files keeps the hook fast for non-frontend work.
# -----------------------------------------------------------------------------
audit_trigger="$(git diff --cached --name-only --diff-filter=ACMRT | grep -E '^frontend/src/(state/|features/|layout/|.*\.css$)' || true)"
if [ -n "${audit_trigger}" ]; then
    AUDIT="${REPO_ROOT}/.tooling/local-ci/audit-w2-residue.py"
    if [ -x "${AUDIT}" ]; then
        # Capture full output, run a parse on the summary line.
        audit_out="$(python3 "${AUDIT}" 2>&1)" || {
            echo "${audit_out}"
            echo ""
            echo "audit-w2-residue.py failed to run. Fix the script or commit with --no-verify if intentional."
            exit 1
        }
        # Summary line: "# summary: A=N / B=N / C=N  (allowlist suppressed M)"
        summary="$(echo "${audit_out}" | grep -E '^# summary:' || true)"
        nonzero="$(echo "${summary}" | grep -oE '[ABC]=[0-9]+' | grep -v '=0$' || true)"
        if [ -n "${nonzero}" ]; then
            echo "${audit_out}"
            echo ""
            echo "audit-w2-residue.py found new W2 residue findings:"
            echo "  ${nonzero}"
            echo ""
            echo "Either:"
            echo "  - fix the underlying issue (= preferred, see Phase J PRs for examples)"
            echo "  - add the finding to .tooling/local-ci/audit-w2-residue-allowlist.txt with a comment"
            echo "  - commit with --no-verify if intentional and tracked elsewhere"
            exit 1
        fi
    else
        echo "warning: ${AUDIT} not found / not executable; skipping W2 residue audit."
    fi
fi
